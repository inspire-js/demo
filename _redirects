# Legacy URLs: the core engine is now the @inspirejs/core package, served here via nudeps.
# These keep old absolute URLs (used by existing decks and docs) resolving.
/inspire.mjs   /client_modules/@inspirejs/core/inspire.mjs       200
/inspire.js    /client_modules/@inspirejs/core/inspire.js        200
/inspire.css   /client_modules/@inspirejs/core/inspire.css       200
/src/*         /client_modules/@inspirejs/core/src/:splat        200
/plugins/*     /client_modules/@inspirejs/plugins/:splat         200

# Catch all NPM fallback
node_modules/:modulename/* https://cdn.jsdelivr.net/npm/:modulename@latest/:splat 200
